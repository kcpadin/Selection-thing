# choose unit
unit = input("Enter unit (C/F/K): ")

# check unit
if unit not in ["C", "F", "K"]:
    print("Invalid")
    exit()

# input temp
temp = float(input("Enter temperature: "))

# convert to Celsius
if unit == "F":
    temp = (temp - 32) * 5/9
elif unit == "K":
    temp = temp - 273.15

# check status
if temp < 0:
    print("Too cold")
elif temp <= 35:
    print("Safe temperature")
else:
    print("Too hot")
